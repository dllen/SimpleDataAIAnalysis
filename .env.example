# ============================================
# Data Analysis Agent - Environment Variables
# ============================================

# --- LLM Configuration ---
# API Base URL (OpenAI-compatible)
# DeepSeek: https://api.deepseek.com
# Kimi (Moonshot): https://api.moonshot.cn/v1
# MiniMax: https://api.minimax.chat/v1
# vLLM (local): http://localhost:8000/v1
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=your-api-key-here
AI_MODEL=deepseek-chat

# --- JWT Configuration ---
# Generate a secure key: openssl rand -base64 32
JWT_SECRET=change_this_in_production_with_a_secure_random_key

# --- DuckDB Storage ---
# Path where DuckDB database files are stored per user
APP_DUCKDB_STORAGE_PATH=./data/duckdb

# --- File Upload ---
# Maximum upload file size in bytes (50MB)
APP_UPLOAD_MAX_FILE_SIZE=52428800
APP_UPLOAD_STORAGE_PATH=./data/uploads

# --- H2 Database (User data & metadata) ---
# Change to PostgreSQL for production
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/agentdb;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# --- Server ---
SERVER_PORT=8080

# --- CORS (Frontend URL for production) ---
# CORS_ALLOWED_ORIGINS=http://localhost:3000
